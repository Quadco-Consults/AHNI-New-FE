{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "components/*": ["src/components/*"],
      "molecules/*": ["src/molecules/*"],
      "atoms/*": ["src/atoms/*"],
      "assets/*": ["src/assets/*"],
      "configs/*": ["src/configs/*"],
      "constants/*": ["src/constants/*"],
      "hooks/*": ["src/hooks/*"],
      "pages/*": ["src/pages/*"],
      "utils/*": ["src/utils/*"],
      "lib/*": ["src/lib/*"],
      "apis/*": ["src/apis/*"],
      "definations/*": ["src/definations/*"],
      "services/*": ["src/services/*"],
      "store/*": ["src/store/*"]
    },
    "jsx": "react-jsx" // This is crucial for JSX support
  },
  "include": ["src"]
}
