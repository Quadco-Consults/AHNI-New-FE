# Development environment - using REXSWIFT API
# Production API (rexswift server)
NEXT_PUBLIC_BASE_URL=https://ahnibe.rexwift.org/api/v1
NEXT_PUBLIC_API_URL=https://ahnibe.rexwift.org/api/v1
# Local backend (commented out)
# NEXT_PUBLIC_BASE_URL=http://127.0.0.1:8000/api/v1
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api/v1

# Enable mock chat for testing enhanced features
NEXT_PUBLIC_USE_MOCK_CHAT=true